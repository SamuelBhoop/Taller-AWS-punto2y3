[Unit]
Description=FastAPI test_docker_fastapi (Uvicorn)
After=network.target

[Service]
Type=simple
User=ubuntu
WorkingDirectory=/home/ubuntu/Taller-AWS-punto2y3/test_docker_fastapi
Environment=PATH=/home/ubuntu/Taller-AWS-punto2y3/test_docker_fastapi/venv/bin:/usr/local/bin:/usr/bin
ExecStart=/home/ubuntu/Taller-AWS-punto2y3/test_docker_fastapi/venv/bin/uvicorn main:app --host 0.0.0.0 --port 8000
Restart=on-failure
RestartSec=5

[Install]
WantedBy=multi-user.target
